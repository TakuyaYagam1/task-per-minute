# --- Docker Compose -----------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=task_per_minute
BACKEND_IMAGE=ghcr.io/takuyayagam1/task-per-minute-backend:latest

# --- HTTP ---------------------------------------------------------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=30s

# --- PostgreSQL ---------------------------------------------------------
DB_DSN=postgres://admin:your-password-here@postgres:5432/task_per_minute?sslmode=disable
DB_MAX_CONNS=20

# --- Redis --------------------------------------------------------------
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=your-password-here
REDIS_DB=0

# --- SeaweedFS ----------------------------------------------------------
SEAWEEDFS_ENDPOINT=localhost:8333
SEAWEEDFS_ACCESS_KEY=admin
SEAWEEDFS_SECRET_KEY=your-password-here
SEAWEEDFS_BUCKET=task-per-minute
SEAWEEDFS_SECURE=false

# --- JWT --------------------------------------------------------------------
JWT_SECRET=change-me-very-long-random-string-32+chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Admin --------------------------------------------------------------
ADMIN_PASSWORD=your-password-here
