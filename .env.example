# --- Docker Compose -----------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=task_per_minute
BACKEND_IMAGE=ghcr.io/takuyayagam1/task-per-minute-backend:replace-with-backend-sha
FRONTEND_IMAGE=ghcr.io/takuyayagam1/task-per-minute-frontend:replace-with-frontend-sha

# Application listen ports. Local compose also publishes them on the host.
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_S3_PORT=8333

# Production edge network and NGINX reverse proxy.
DOCKER_INTERNAL_SUBNET=172.30.0.0/24
NGINX_IMAGE=nginx:1.30.0-alpine3.23
CERTBOT_IMAGE=certbot/certbot:v5.5.0
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
CERTBOT_CERT_NAME=task-per-minute
# ACME_EMAIL: strongly recommended in prod. Let's Encrypt sends renewal /
# revocation warnings here; without it certbot uses --register-unsafely-without-email
# and you will not be notified before a certificate expires.
ACME_EMAIL=
USE_LE_STAGING=false
CERTBOT_RENEW_INTERVAL_SECONDS=43200
APP_DOMAIN=localhost
ADMIN_DOMAIN=admin.localhost
API_DOMAIN=api.localhost
FILES_DOMAIN=localhost

# --- HTTP ---------------------------------------------------------------
HTTP_HOST=0.0.0.0
HTTP_READ_TIMEOUT=5m
HTTP_WRITE_TIMEOUT=5m
HTTP_SHUTDOWN_TIMEOUT=30s
# HTTP_ALLOWED_ORIGINS: comma-separated full origins (scheme://host[:port]).
# The default is fine for local docker compose; in PRODUCTION you MUST replace
# it with the public app origin (e.g. `https://app.example.com`), otherwise the
# browser will reject every REST call with a CORS error.
HTTP_ALLOWED_ORIGINS=http://localhost:3000
HTTP_TRUSTED_PROXY_CIDRS=172.30.0.0/24

# --- PostgreSQL ---------------------------------------------------------
DB_DSN=postgres://admin:your-password-here@postgres:5432/task_per_minute?sslmode=disable
DB_MAX_CONNS=20

# --- Redis --------------------------------------------------------------
# REDIS_ADDR is consumed by the backend. Inside docker compose use the service
# name (`redis:6379`); when running the backend natively (`make run`) point it
# at the host-published port (e.g. `localhost:6379`).
REDIS_ADDR=redis:6379
REDIS_PASSWORD=your-password-here
REDIS_DB=0

# --- SeaweedFS ----------------------------------------------------------
# SEAWEEDFS_ENDPOINT: backend -> S3 control plane. Inside docker compose use the
# service name (`seaweedfs:8333`); for native runs use `localhost:8333`.
SEAWEEDFS_ENDPOINT=seaweedfs:8333
# SEAWEEDFS_PUBLIC_ENDPOINT: host:port the BROWSER hits to download presigned
# task source archives. The default is fine for local compose because the
# seaweedfs S3 port is published to the host. In PRODUCTION you MUST replace it
# with the public files domain (e.g. `files.example.com`), otherwise every
# client will try to download from its own localhost.
SEAWEEDFS_PUBLIC_ENDPOINT=localhost:8333
SEAWEEDFS_ACCESS_KEY=admin
SEAWEEDFS_SECRET_KEY=your-password-here
SEAWEEDFS_BUCKET=task-per-minute
SEAWEEDFS_SECURE=false
SEAWEEDFS_PUBLIC_SECURE=false

# --- JWT --------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-here-32-plus-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Admin --------------------------------------------------------------
# ADMIN_PASSWORD accepts either:
#   - a plain-text password (MVP / local), or
#   - a bcrypt hash starting with $2a$ / $2b$ / $2y$ (recommended for prod;
#     generate via `htpasswd -bnBC 12 "" your-password | tr -d ':\n'`).
#
# IMPORTANT: docker-compose performs variable interpolation when reading .env.
# A literal `$` in a bcrypt hash MUST be doubled to `$$`, otherwise compose
# will treat `$2a$12$saltchars` as variable references and silently truncate
# the hash, breaking admin login.
#   correct: ADMIN_PASSWORD=$$2a$$12$$zddK...vWo1RxTy
#   broken : ADMIN_PASSWORD=$2a$12$zddK...vWo1RxTy   (compose eats $2, $12, $zddK)
ADMIN_PASSWORD=your-password-here
ADMIN_LOGIN_RATE_ATTEMPTS=3
ADMIN_LOGIN_RATE_WINDOW=3m
ADMIN_LOGIN_RATE_BUCKET_TTL=15m

# --- Player -------------------------------------------------------------
PLAYER_JOIN_RATE_ATTEMPTS=20
PLAYER_JOIN_RATE_WINDOW=5m
PLAYER_JOIN_RATE_BUCKET_TTL=1h

# --- WebSocket ----------------------------------------------------------
# WS_ALLOWED_ORIGINS: comma-separated full origins for the WebSocket handshake
# Origin check. Same rules as HTTP_ALLOWED_ORIGINS — replace in PRODUCTION
# (e.g. `https://app.example.com`); a mismatch closes the connection with code
# 1008 and the frontend cannot reconnect.
WS_ALLOWED_ORIGINS=http://localhost:3000
# Per-IP /ws handshake rate-limit (token bucket). Drops connection attempts
# beyond ATTEMPTS within WINDOW; bucket forgotten after BUCKET_TTL idle.
WS_HANDSHAKE_RATE_ATTEMPTS=60
WS_HANDSHAKE_RATE_WINDOW=1m
WS_HANDSHAKE_RATE_BUCKET_TTL=15m

# --- Frontend -----------------------------------------------------------
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ADMIN_API_URL=
NEXT_PUBLIC_WS_URL=
