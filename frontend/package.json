{
  "name": "task-per-minute",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0 --ignore-pattern .next --ignore-pattern node_modules --ignore-pattern lib/shared/api/schema.ts",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0 --ignore-pattern .next --ignore-pattern node_modules --ignore-pattern lib/shared/api/schema.ts --fix",
    "typecheck": "tsc --noEmit --pretty false",
    "openapi:generate": "sh -c 'cd ../backend && python3 scripts/merge-schemas.py && cd ../frontend && trap \"rm -f ../backend/internal/openapi/components/schemas.yml\" EXIT && openapi-typescript ../backend/internal/openapi/openapi.yml -o lib/shared/api/schema.ts'",
    "codegen": "npm run openapi:generate",
    "gen:types": "npm run openapi:generate",
    "test:e2e": "playwright test",
    "test:e2e:live": "E2E_LIVE=1 playwright test e2e/live-backend.spec.ts",
    "test:e2e:full-stack": "../scripts/e2e-local-compose.sh",
    "check": "npm run openapi:generate && npm run typecheck && npm run lint && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "next": "^15.5.15",
    "openapi-fetch": "^0.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "styled-jsx": "^5.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.13",
    "minimatch@3.1.5": {
      "brace-expansion": "^1.1.13"
    }
  }
}
